# Normalize line endings to LF on checkout for all text files
* text=auto eol=lf

# Always use LF for .env files (prevents CRLF on Windows adding \r to env vars)
.env text eol=lf
.env.* text eol=lf

# Shell scripts
*.sh text eol=lf

# C# source files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf

# Web / config
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# TypeScript / JavaScript
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf

# Styles
*.css text eol=lf
*.scss text eol=lf

# HTML
*.html text eol=lf

# Binaries — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.dll binary
*.exe binary
