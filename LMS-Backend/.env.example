# ============================================
# LiveExpert.AI — Environment Configuration
# Copy this file to .env and fill in values.
# NEVER commit .env to git.
# ============================================

# Database Connection (SQLite path or PostgreSQL DSN)
CONNECTIONSTRINGS__DEFAULTCONNECTION=Data Source=/app/data/liveexpert.db
CONNECTIONSTRINGS__REDIS=

# Encryption (must be at least 32 characters)
ENCRYPTION__KEY=CHANGE_ME_AT_LEAST_32_CHARS_LONG_HERE

# JWT
JWT__KEY=CHANGE_ME_SUPER_SECRET_KEY_AT_LEAST_32_CHARS
JWT__ISSUER=LiveExpert.AI
JWT__AUDIENCE=LiveExpert.AI.Users
JWT__ACCESSTOKENEXPIRATIONMINUTES=60
JWT__REFRESHTOKENEXPIRATIONDAYS=7

# Google OAuth
GOOGLE__CLIENTID=
GOOGLE__CLIENTSECRET=

# Razorpay
RAZORPAY__KEYID=
RAZORPAY__KEYSECRET=
RAZORPAY__WEBHOOKSECRET=

# SMTP Email
MAIL__HOST=smtp.gmail.com
MAIL__PORT=587
MAIL__USERNAME=
MAIL__PASSWORD=
MAIL__ENCRYPTION=tls
MAIL__FROMADDRESS=
MAIL__FROMNAME=LiveExpert Support

# SendGrid
SENDGRID__APIKEY=
SENDGRID__FROMEMAIL=
SENDGRID__FROMNAME=

# Twilio
TWILIO__ACCOUNTSID=
TWILIO__AUTHTOKEN=
TWILIO__PHONENUMBER=

# Azure Blob Storage (for file uploads)
AZURESTORAGE__CONNECTIONSTRING=
AZURESTORAGE__CONTAINERNAME=liveexpert-files

# Google Calendar
GOOGLECALENDAR__CLIENTID=
GOOGLECALENDAR__CLIENTSECRET=
GOOGLECALENDAR__REDIRECTURI=https://YOUR_DOMAIN/api/calendar/oauth/callback

# Affinda Resume Parser
AFFINDA__APIKEY=
AFFINDA__WORKSPACEID=
AFFINDA__DOCUMENTTYPE=

# Hangfire Dashboard
HANGFIRE__DASHBOARDPATH=/hangfire
HANGFIRE__USERNAME=admin
HANGFIRE__PASSWORD=CHANGE_ME

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v22.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_ID=
WHATSAPP_ACCESS_TOKEN=

# Google AI
GOOGLEAI__APIKEY=

# Anthropic (Claude AI)
ANTHROPIC__APIKEY=
ANTHROPIC__MODEL=claude-haiku-4-5-20251001

# App settings
APPSETTINGS__REGISTRATIONBONUSCREDITS=100
APPSETTINGS__REFERRALBONUSCREDITS=500
APPSETTINGS__MINWITHDRAWALAMOUNT=1000
APPSETTINGS__SESSIONCREDITRELEASEDELAYDAYS=3
APPSETTINGS__MAXPAYOUTPERCENTAGE=90
